rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSession(data) {
      return data.keys().hasAll(['isOnline', 'lastActive'])
        && (data.lastActive == request.time || data.lastActive is string)
        && data.isOnline is bool;
    }

    function isValidGameStats(data) {
      return data.keys().hasAll(['ratingSum', 'ratingCount'])
        && data.ratingSum is number
        && data.ratingCount is number;
    }

    // Stats collection (Visit Count)
    match /stats/{statsId} {
      allow read: if isValidId(statsId);
      allow write: if isValidId(statsId) && incoming().visitCount is number;
    }

    // Game Stats collection (Ratings)
    match /game_stats/{gameId} {
      allow read: if isValidId(gameId);
      allow list: if true;
      allow write: if isValidId(gameId) && isValidGameStats(incoming());
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow read: if isValidId(sessionId);
      allow list: if true;
      allow create: if isValidId(sessionId) && isValidSession(incoming());
      allow update: if isValidId(sessionId) && (
        // Only owner can update privileges
        (incoming().diff(existing()).affectedKeys().hasAny(['isAdmin', 'privileges']) && request.auth == null && sessionId != '4CDVMIEU6') == false
        // Note: request.auth is null in this sandbox, we use sessionId to identify owner on client
        // In this environment, we rely on the client logic to prevent unauthorized privilege elevation 
        // as we don't have proper Firebase Auth setup in the way standard apps do (it's using anonymous-like logic).
        // Since we can't reliably distinguish owner server-side without real Auth AND we have a blank match for owner,
        // we will keep it flexible but add common-sense checks.
      ) && (isValidSession(incoming()) || incoming().keys().hasAny(['ratings', 'username', 'gameLocks', 'progressions', 'password', 'isAdmin', 'privileges', 'playStats']));
    }

    // Bans collection
    match /bans/{banId} {
      allow read: if isValidId(banId);
      allow list: if true;
      allow write: if isValidId(banId);
    }
  }
}
