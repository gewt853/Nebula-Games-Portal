rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSession(data) {
      return data.keys().hasAll(['isOnline', 'lastActive'])
        && (data.lastActive == request.time || data.lastActive is string)
        && data.isOnline is bool;
    }

    function isValidGameStats(data) {
      return data.keys().hasAll(['ratingSum', 'ratingCount'])
        && data.ratingSum is number
        && data.ratingCount is number;
    }

    // Stats collection (Visit Count)
    match /stats/{statsId} {
      allow read: if isValidId(statsId);
      allow write: if isValidId(statsId) && incoming().visitCount is number;
    }

    // Game Stats collection (Ratings)
    match /game_stats/{gameId} {
      allow read, list: if isValidId(gameId);
      allow write: if isValidId(gameId) && isValidGameStats(incoming());
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow read, list: if isValidId(sessionId);
      allow create: if isValidId(sessionId) && isValidSession(incoming());
      allow update: if isValidId(sessionId) && (isValidSession(incoming()) || incoming().keys().hasAny(['ratings', 'username', 'gameLocks', 'progressions']));
    }

    // Bans collection
    match /bans/{banId} {
      allow read, list: if isValidId(banId);
      allow write: if isValidId(banId);
    }
  }
}
