rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSession(data) {
      return data.keys().hasAll(['isOnline', 'lastActive'])
        && (data.lastActive == request.time || data.lastActive is string)
        && data.isOnline is bool;
    }

    function isValidGameStats(data) {
      return data.keys().hasAll(['ratingSum', 'ratingCount'])
        && data.ratingSum is number
        && data.ratingCount is number;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp'])
        && data.text is string && data.text.size() <= 1000
        && data.senderId is string && data.senderId.size() <= 128
        && data.senderName is string && data.senderName.size() <= 64
        && data.timestamp == request.time;
    }

    function isValidBan(data) {
      return data.keys().hasAll(['bannedAt', 'reason', 'ruleBroken'])
        && data.bannedAt == request.time
        && data.reason is string && data.reason.size() <= 500
        && data.ruleBroken is string && data.ruleBroken.size() <= 200;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['timestamp', 'action', 'targetId', 'actorId', 'details'])
        && data.timestamp == request.time
        && data.action is string && data.action.size() <= 100
        && data.targetId is string && data.targetId.size() <= 128
        && data.actorId is string && data.actorId.size() <= 128
        && data.details is string && data.details.size() <= 1000;
    }

    // Stats collection (Visit Count)
    match /stats/{statsId} {
      allow read: if isValidId(statsId);
      allow write: if isValidId(statsId) && incoming().visitCount is number;
    }

    // Game Stats collection (Ratings)
    match /game_stats/{gameId} {
      allow read: if isValidId(gameId);
      allow list: if true;
      allow write: if isValidId(gameId) && isValidGameStats(incoming());
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow read: if isValidId(sessionId);
      allow list: if true;
      allow create: if isValidId(sessionId) && isValidSession(incoming());
      allow update: if isValidId(sessionId) && (
        // Case 1: Not touching sensitive fields
        (!incoming().diff(existing()).affectedKeys().hasAny(['isAdmin', 'privileges'])) ||
        // Case 2: Sensitive update by authorized actor
        (
          // Protect the owner session from any privilege changes by others
          (sessionId != '4CDVMIEU6') && 
          // Verify actor is authorized
          (
            incoming().managedBy == '4CDVMIEU6' || 
            get(/databases/$(database)/documents/sessions/$(incoming().managedBy)).data.privileges.manageAdmins == true
          )
        )
      ) && (
        isValidSession(incoming()) || 
        incoming().keys().hasAny(['ratings', 'username', 'gameLocks', 'progressions', 'password', 'isAdmin', 'privileges', 'playStats', 'favorites', 'agreedChatRules', 'agreedSiteRules', 'managedBy'])
      );
    }

    // Bans collection
    match /bans/{banId} {
      allow read: if isValidId(banId);
      allow list: if true;
      allow write: if isValidId(banId);
    }

    // Chat messages
    match /messages/{messageId} {
      allow read, list: if true;
      allow create: if isValidMessage(incoming());
      allow update, delete: if false;
    }

    // Audit logs
    match /audit_logs/{logId} {
      allow read, list: if true;
      allow create: if isValidLog(incoming());
      allow update, delete: if false;
    }
  }
}
