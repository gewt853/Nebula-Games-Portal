{
  "entities": {
    "stats": {
      "title": "Site Statistics",
      "description": "Global statistics for the site.",
      "type": "object",
      "properties": {
        "visitCount": {
          "type": "number",
          "description": "The total number of visits to the site."
        }
      },
      "required": ["visitCount"]
    },
    "session": {
      "title": "User Session",
      "description": "Active user session tracking.",
      "type": "object",
      "properties": {
        "lastActive": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "username": { "type": "string" },
        "progressions": {
          "type": "object",
          "description": "Store state for games, keyed by game ID."
        },
        "gameLocks": {
          "type": "object",
          "description": "Password protection for specific games, keyed by game ID."
        },
        "ratings": {
          "type": "object",
          "description": "User ratings for games, keyed by game ID."
        },
        "password": {
          "type": "string",
          "description": "Password set by the user to protect their session."
        },
        "playStats": {
          "type": "object",
          "description": "Tracking game engagement, keyed by game ID with duration and lastPlayed fields."
        },
        "favorites": {
          "type": "object",
          "description": "User favorite games, keyed by game ID (boolean value)."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether this user has admin status."
        },
        "agreedSiteRules": {
          "type": "boolean",
          "description": "Whether this user agreed to the general site rules."
        },
        "agreedChatRules": {
          "type": "boolean",
          "description": "Whether this user agreed to the chat-specific rules."
        },
        "privileges": {
          "type": "object",
          "properties": {
            "banUser": { "type": "boolean" },
            "viewUser": { "type": "boolean" },
            "fullAccess": { "type": "boolean" }
          },
          "description": "Granular administrative privileges."
        }
      },
      "required": ["lastActive", "isOnline"]
    },
    "game_stats": {
      "title": "Game Statistics",
      "description": "Aggregate statistics for games.",
      "type": "object",
      "properties": {
        "ratingSum": { "type": "number" },
        "ratingCount": { "type": "number" }
      },
      "required": ["ratingSum", "ratingCount"]
    },
    "ban": {
      "title": "Banned User",
      "description": "Users restricted from accessing the portal.",
      "type": "object",
      "properties": {
        "bannedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "ruleBroken": { "type": "string" }
      },
      "required": ["bannedAt", "reason"]
    },
    "audit_log": {
      "title": "Audit Log",
      "description": "Records of administrative or critical user actions.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "actorId": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["timestamp", "action", "targetId", "actorId"]
    },
    "message": {
      "title": "Chat Message",
      "description": "A message sent in the global chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "system": { "type": "boolean" }
      },
      "required": ["text", "senderId", "senderName", "timestamp"]
    }
  },
  "firestore": {
    "stats/global": {
      "schema": "stats",
      "description": "Global statistics document."
    },
    "sessions/{sessionId}": {
      "schema": "session",
      "description": "Active user sessions."
    },
    "bans/{banId}": {
      "schema": "ban",
      "description": "Banned session IDs."
    },
    "game_stats/{gameId}": {
      "schema": "game_stats",
      "description": "Aggregate statistics for specific games."
    },
    "messages/{messageId}": {
      "schema": "message",
      "description": "Global chat messages."
    },
    "audit_logs/{logId}": {
      "schema": "audit_log",
      "description": "System-wide audit logs."
    }
  }
}
